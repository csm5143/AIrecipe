generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 管理员账号 ====================
model Admin {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  password     String
  nickname     String?
  avatar       String?
  role         AdminRole @default(EDITOR)
  status       AccountStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  operationLogs OperationLog[]

  @@map("admins")
}

enum AdminRole {
  SUPER_ADMIN   // 超级管理员
  ADMIN        // 管理员
  EDITOR       // 编辑
}

enum AccountStatus {
  ACTIVE
  DISABLED
}

// ==================== 操作日志 ====================
model OperationLog {
  id         Int      @id @default(autoincrement())
  adminId    Int
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action     String
  module     String
  targetId   String?
  detail     String?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("operation_logs")
}

// ==================== 用户管理 ====================
model User {
  id           Int         @id @default(autoincrement())
  openid       String      @unique
  unionid      String?     @unique
  nickname     String?
  avatar       String?
  phone        String?     @unique
  gender       Gender?     @default(UNKNOWN)
  birthday     DateTime?
  status       AccountStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  favorites    Favorite[]
  collections  Collection[]
  feedbacks    Feedback[]
  shoppingLists ShoppingList[]
  aiScans      AiScan[]

  @@index([openid])
  @@index([unionid])
  @@index([createdAt])
  @@map("users")
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

// ==================== 食谱 ====================
model Recipe {
  id           Int       @id @default(autoincrement())
  title        String
  coverImage   String?
  description  String?
  difficulty   Difficulty @default(MEDIUM)
  cookingTime  Int?
  servings     Int?
  calories     Int?
  tags         Json?
  ingredients  Json
  steps        Json
  tips         String?
  nutrition    Json?
  cuisine      String?
  category     String?
  isAiGenerated Boolean  @default(false)
  aiPrompt     String?
  viewCount    Int       @default(0)
  collectCount Int       @default(0)
  shareCount   Int       @default(0)
  status       ContentStatus @default(DRAFT)
  isFeatured   Boolean   @default(false)
  isDeleted    Boolean   @default(false)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  favorites    Favorite[]
  recipeIngredients RecipeIngredient[]

  @@index([status])
  @@index([isFeatured])
  @@index([createdAt])
  @@index([category])
  @@map("recipes")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  OFFLINE
  DELETED
  ACTIVE
}

// ==================== 食材 ====================
model Ingredient {
  id           Int       @id @default(autoincrement())
  name         String
  alias        String?
  coverImage   String?
  category     String?
  unit         String?
  calories     Float?
  nutrition    Json?
  tags         Json?
  status       ContentStatus @default(ACTIVE)
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  recipeIngredients RecipeIngredient[]

  @@index([name])
  @@index([category])
  @@map("ingredients")
}

// ==================== 食谱-食材关联 ====================
model RecipeIngredient {
  id           Int       @id @default(autoincrement())
  recipeId     Int
  ingredientId Int?
  name         String
  amount       String
  unit         String?
  isOptional   Boolean   @default(false)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())

  recipe       Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id])

  @@index([recipeId])
  @@map("recipe_ingredients")
}

// ==================== 收藏夹 ====================
model Collection {
  id           Int       @id @default(autoincrement())
  userId       Int
  name         String
  description  String?
  coverImage   String?
  isPublic     Boolean   @default(false)
  itemCount    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        CollectionItem[]

  @@index([userId])
  @@map("collections")
}

model CollectionItem {
  id           Int       @id @default(autoincrement())
  collectionId Int
  recipeId     Int
  note         String?
  createdAt    DateTime  @default(now())

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@unique([collectionId, recipeId])
  @@index([collectionId])
  @@map("collection_items")
}

// ==================== 收藏（点赞） ====================
model Favorite {
  id           Int       @id @default(autoincrement())
  userId       Int
  recipeId     Int
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe       Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([userId])
  @@index([recipeId])
  @@map("favorites")
}

// ==================== 购物清单 ====================
model ShoppingList {
  id           Int       @id @default(autoincrement())
  userId       Int
  name         String
  status       ListStatus @default(ACTIVE)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items        ShoppingItem[]

  @@index([userId])
  @@map("shopping_lists")
}

model ShoppingItem {
  id           Int       @id @default(autoincrement())
  listId       Int
  name         String
  amount       String?
  unit         String?
  category     String?
  isChecked    Boolean   @default(false)
  createdAt    DateTime  @default(now())

  shoppingList ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("shopping_items")
}

enum ListStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

// ==================== 用户反馈 ====================
model Feedback {
  id           Int       @id @default(autoincrement())
  userId       Int?
  type         FeedbackType @default(OTHER)
  content      String
  images       Json?
  contact      String?
  status       FeedbackStatus @default(PENDING)
  reply        String?
  repliedAt    DateTime?
  repliedBy    Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user         User?     @relation(fields: [userId], references: [id])
  replies      FeedbackReply[]

  @@index([status])
  @@index([userId])
  @@index([createdAt])
  @@map("feedbacks")
}

model FeedbackReply {
  id           Int       @id @default(autoincrement())
  feedbackId   Int
  adminId      Int?
  content      String
  createdAt    DateTime  @default(now())

  feedback     Feedback  @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
  @@map("feedback_replies")
}

enum FeedbackType {
  BUG_REPORT
  FEATURE_REQUEST
  CONTENT_ISSUE
  OTHER
}

enum FeedbackStatus {
  PENDING
  REPLIED
  RESOLVED
  CLOSED
}

// ==================== AI 扫描记录 ====================
model AiScan {
  id           Int       @id @default(autoincrement())
  userId       Int
  imageUrl     String
  result       Json
  recipes      Json?
  status       ScanStatus @default(SUCCESS)
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("ai_scans")
}

enum ScanStatus {
  PROCESSING
  SUCCESS
  FAILED
}

// ==================== 内容运营 ====================
model Banner {
  id           Int       @id @default(autoincrement())
  title        String
  imageUrl     String
  linkType     LinkType  @default(NONE)
  linkValue    String?
  sortOrder    Int       @default(0)
  status       ContentStatus @default(ACTIVE)
  startTime    DateTime?
  endTime      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, startTime, endTime])
  @@map("banners")
}

enum LinkType {
  NONE
  RECIPE
  PAGE
  LINK
}

model Notice {
  id           Int       @id @default(autoincrement())
  title        String
  content      String
  type         NoticeType @default(SYSTEM)
  target       NoticeTarget @default(ALL)
  status       ContentStatus @default(ACTIVE)
  publishedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("notices")
}

enum NoticeType {
  SYSTEM
  ACTIVITY
  UPDATE
}

enum NoticeTarget {
  ALL
  NEW_USER
  ACTIVE_USER
}
