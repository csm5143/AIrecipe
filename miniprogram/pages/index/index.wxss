/* =============================================
   首页布局：整页滚动，内容 + 热门菜品连续滚动
   ============================================= */
.home.page {
  height: 100vh;
  overflow: hidden;
  background: #f5f5f7;
}

.home-scroll {
  height: 100vh;
  overflow-y: auto;
  /* iOS 惯性滚动手感 */
  -webkit-overflow-scrolling: touch;
  /* Android 阻止全局拉刷新/下拉手势干扰 */
  overscroll-behavior: contain;
}

.content {
  padding: 0 28rpx 120rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.brand-block {
  text-align: center;
  padding: 16rpx 0 42rpx;
}

.brand-title-img {
  height: 100rpx;
  width: auto;
  display: block;
  margin: 0 auto;
}

.brand-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #8e8e93;
}

/* 首页入口：跳转菜谱搜索页 */
.home-search-entry {
  display: flex;
  align-items: center;
  padding: 34rpx;
  background: #ffffff;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.home-search-entry:active {
  opacity: 0.92;
}

.home-search-entry__icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  opacity: 0.5;
}

.home-search-entry__placeholder {
  flex: 1;
  font-size: 30rpx;
  color: #aeaeb2;
}

/* 横向分类 */
.cat-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: flex-start;
  padding: 8rpx 2rpx 46rpx;
}

.cat-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  vertical-align: top;
}

.cat-bubble {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 15rpx 25rpx rgba(0, 0, 0, 0.15);
  margin-bottom: 16rpx;
}

.cat-bubble__img {
  width: 64rpx;
  height: 64rpx;
}

.cat-bubble__img--stir-fry {
  width: 81rpx;
  height: 88rpx;
}

.cat-bubble__img--soup {
  width: 88rpx;
  height: 76rpx;
}

.cat-bubble__img--breakfast {
  width: 56rpx;
  height: 56rpx;
}

.cat-bubble__img--baked {
  width: 63rpx;
  height: 62rpx;
}

.cat-bubble__img--more {
  width: 58rpx;
  height: 58rpx;
}

.cat-label {
  font-size: 26rpx;
  color: #636366;
  text-align: center;
  white-space: normal;
  width: 100%;
  line-height: 1.25;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 24rpx;
}

.section-head__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.tile-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.tile-card {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 18rpx rgba(0, 0, 0, 0.04);
}

.tile-card:active {
  opacity: 0.9;
}

.tile-card--scan {
  border: 1rpx solid rgba(226, 166, 80, 0.35);
  background: linear-gradient(135deg, #fffbf0 0%, #ffffff 100%);
  position: relative;
  overflow: hidden;
}

.tile-card--scan::before {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(226, 166, 80, 0.08);
}

.scan-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f5a623 0%, #f7c948 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 6rpx 16rpx rgba(226, 166, 80, 0.35);
}

.tile-card__icon.scan-icon {
  width: 51rpx;
  height: 51rpx;
  margin-right: 0;
}

.scan-title {
  font-weight: 700;
  color: #b37400;
  font-size: 32rpx;
}

.scan-desc {
  color: #a07820;
  font-size: 24rpx;
}

.scan-arrow {
  font-size: 44rpx;
  color: #d4a020;
  font-weight: 300;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.tile-card--select {
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.select-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f0f0f0 0%, #e8e8e8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tile-card__icon.select-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 0;
}

.tile-card__icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.tile-card__info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.tile-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.tile-card__desc {
  font-size: 24rpx;
  color: #8e8e93;
}

/* =============================================
   热门菜品网格
   ============================================= */
.hot-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 42rpx 16rpx;
}

.hot-card {
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.hot-card:active {
  opacity: 0.92;
}

.hot-cover-wrap {
  width: 100%;
  border-radius: 16rpx;
  overflow: hidden;
  background: #ececec;
}

.hot-cover {
  display: block;
  width: 100%;
  height: 280rpx;
  vertical-align: top;
}

.hot-cover--placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f2f2f7 0%, #e5e5ea 100%);
}

.hot-cover__ph {
  font-size: 24rpx;
  color: #aeaeb2;
}

.hot-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #1c1c1e;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 底部加载状态 */
.hot-loading {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  padding: 36rpx 0;
  gap: 14rpx;
}

.hot-loading__spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #e5e5ea;
  border-top-color: #f7c948;
  border-radius: 50%;
  animation: hot-spin 0.7s linear infinite;
}

.hot-loading__text {
  font-size: 26rpx;
  color: #aeaeb2;
}

/* 底部「没有更多了」 */
.hot-no-more {
  display: flex;
  justify-content: center;
  padding: 36rpx 0 0;
}

.hot-no-more__text {
  font-size: 24rpx;
  color: #c7c7cc;
}

/* 懒加载三点加载动画 */
.loading-more {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0 10rpx;
}

.loading-more__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #ff9500;
  animation: loading-bounce 0.6s ease-in-out infinite;
}

.loading-more__dot:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-more__dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes loading-bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* IntersectionObserver 触发区（透明占位，不可点击） */
.load-more-trigger {
  height: 1rpx;
  width: 100%;
}

@keyframes hot-spin {
  to { transform: rotate(360deg); }
}
