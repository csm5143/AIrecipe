/* ============================================
   scan 页面样式 - 温馨厨房手绘风
   ============================================ */

page {
  height: 100%;
  background: #FFF8EE;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100%;
  font-family: 'PingFang SC', 'Helvetica Neue', sans-serif;
  overflow: hidden;
  position: relative;
}

/* ============================================
   第一步：选择图片
   ============================================ */

.upload-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
  position: relative;
  overflow: hidden;
}

/* --- 背景装饰圆点 --- */
.bg-dots {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
}

.bg-dot {
  position: absolute;
  border-radius: 50%;
  opacity: 0.18;
}
.bg-dot--1 {
  width: 320rpx;
  height: 320rpx;
  background: #E8924A;
  top: -80rpx;
  right: -60rpx;
  animation: floatDot 6s ease-in-out infinite;
}
.bg-dot--2 {
  width: 200rpx;
  height: 200rpx;
  background: #C4703C;
  bottom: 120rpx;
  left: -40rpx;
  animation: floatDot 8s ease-in-out infinite reverse;
}
.bg-dot--3 {
  width: 160rpx;
  height: 160rpx;
  background: #E8A86B;
  top: 40%;
  left: 60%;
  animation: floatDot 7s ease-in-out infinite 2s;
}

@keyframes floatDot {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(-16rpx); }
}

/* --- 木质砧板插画 --- */
.board-wrap {
  position: relative;
  z-index: 1;
  margin-bottom: 40rpx;
}

.board {
  position: relative;
  width: 480rpx;
  height: 300rpx;
  background: linear-gradient(160deg, #D4A26A 0%, #C08B55 40%, #B07D45 100%);
  border-radius: 20rpx;
  box-shadow:
    0 12rpx 40rpx rgba(160, 100, 40, 0.28),
    0 4rpx 12rpx rgba(160, 100, 40, 0.15),
    inset 0 2rpx 0 rgba(255, 220, 160, 0.3);
  overflow: hidden;
}

/* 木纹 */
.board-grain {
  position: absolute;
  inset: 0;
  background-image: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 14rpx,
    rgba(0, 0, 0, 0.04) 14rpx,
    rgba(0, 0, 0, 0.04) 16rpx
  );
  border-radius: 20rpx;
}

/* 砧板顶部高光边 */
.board-edge {
  position: absolute;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(to bottom, rgba(255, 220, 160, 0.4), transparent);
}
.board-edge--top { top: 0; border-radius: 20rpx 20rpx 0 0; }
.board-edge--bottom {
  bottom: 0;
  top: auto;
  height: 10rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.12), transparent);
  border-radius: 0 0 20rpx 20rpx;
}

/* 食材们 */
.board-items {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding: 40rpx;
}

.board-item {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 番茄 */
.board-item--tomato {
  animation: floatVeg 3s ease-in-out infinite;
}
.veggie.tomato {
  width: 64rpx;
  height: 56rpx;
  background: radial-gradient(ellipse at 35% 35%, #FF7B5C, #E84040);
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  box-shadow: inset -8rpx -8rpx 16rpx rgba(0,0,0,0.12), 2rpx 4rpx 8rpx rgba(0,0,0,0.15);
}
.veggie-stem {
  width: 20rpx;
  height: 10rpx;
  background: #4CAF50;
  border-radius: 4rpx 4rpx 0 0;
  margin-bottom: -2rpx;
  position: relative;
}
.veggie-stem::after {
  content: '';
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 16rpx;
  height: 12rpx;
  background: #388E3C;
  border-radius: 50% 50% 0 0;
}

/* 鸡蛋 */
.board-item--egg {
  animation: floatVeg 3s ease-in-out infinite 0.6s;
}
.veggie.egg {
  width: 52rpx;
  height: 64rpx;
  background: radial-gradient(ellipse at 38% 30%, #FFF9E6, #F5E0B8);
  border-radius: 50% 50% 50% 50% / 58% 58% 42% 42%;
  box-shadow: inset -6rpx -6rpx 12rpx rgba(0,0,0,0.08), 2rpx 4rpx 8rpx rgba(0,0,0,0.12);
}

/* 胡萝卜 */
.board-item--carrot {
  animation: floatVeg 3s ease-in-out infinite 1.2s;
  flex-direction: column-reverse;
}
.veggie.carrot {
  width: 28rpx;
  height: 72rpx;
  background: linear-gradient(to bottom, #FF8C42 0%, #E87030 60%, #D4622A 100%);
  border-radius: 10rpx 10rpx 40% 40% / 10rpx 10rpx 60% 60%;
  box-shadow: inset -4rpx 0 8rpx rgba(0,0,0,0.12), 2rpx 4rpx 8rpx rgba(0,0,0,0.15);
  position: relative;
}
.veggie.carrot::after {
  content: '';
  position: absolute;
  bottom: -4rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #C45520;
  border-radius: 50%;
}
.veggie-leaf {
  width: 28rpx;
  height: 20rpx;
  background: linear-gradient(to bottom, #66BB6A, #43A047);
  border-radius: 50% 50% 20% 20%;
  margin-bottom: -4rpx;
  position: relative;
  z-index: 1;
}
.veggie-leaf::before,
.veggie-leaf::after {
  content: '';
  position: absolute;
  width: 18rpx;
  height: 14rpx;
  background: #4CAF50;
  border-radius: 50% 50% 20% 20%;
  top: 0;
}
.veggie-leaf::before { left: -6rpx; transform: rotate(-20deg); }
.veggie-leaf::after  { right: -6rpx; transform: rotate(20deg); }

/* 肉块 */
.board-item--meat {
  animation: floatVeg 3s ease-in-out infinite 1.8s;
}
.veggie.meat {
  width: 72rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #F5B5A8, #E8908A, #D47070);
  border-radius: 8rpx 12rpx 8rpx 12rpx;
  box-shadow: inset -6rpx -6rpx 12rpx rgba(0,0,0,0.1), 2rpx 4rpx 8rpx rgba(0,0,0,0.12);
  position: relative;
}
/* 肥肉层 */
.veggie.meat::before {
  content: '';
  position: absolute;
  top: 8rpx;
  right: 10rpx;
  width: 24rpx;
  height: 32rpx;
  background: rgba(255, 240, 220, 0.55);
  border-radius: 4rpx;
}

/* 小葱 */
.board-item--scallion {
  animation: floatVeg 3s ease-in-out infinite 0.4s;
  flex-direction: column-reverse;
}
.veggie.scallion {
  width: 20rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, #4CAF50 0%, #66BB6A 15%, #FAFAFA 15%, #F5F5F5 100%);
  border-radius: 10rpx;
  box-shadow: 2rpx 4rpx 8rpx rgba(0,0,0,0.12);
}

@keyframes floatVeg {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  25%       { transform: translateY(-5rpx) rotate(2deg); }
  75%       { transform: translateY(-3rpx) rotate(-2deg); }
}

/* 刀痕 */
.board-cut {
  position: absolute;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 2rpx;
}
.board-cut--1 { width: 80%; height: 2rpx; top: 35%; left: 10%; transform: rotate(-5deg); }
.board-cut--2 { width: 70%; height: 2rpx; top: 55%; left: 15%; transform: rotate(3deg); }
.board-cut--3 { width: 60%; height: 2rpx; top: 72%; left: 20%; transform: rotate(-2deg); }

/* --- 标题区 --- */
.upload-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.upload-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: rgba(232, 144, 66, 0.1);
  border: 1.5rpx solid rgba(232, 144, 66, 0.3);
  border-radius: 100rpx;
  margin-bottom: 24rpx;
}

.badge-star {
  font-size: 18rpx;
  color: #E8924A;
}

.badge-text {
  font-size: 22rpx;
  color: #E8924A;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.upload-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #4A2C0E;
  margin-bottom: 12rpx;
  letter-spacing: 3rpx;
  font-family: 'PingFang SC', sans-serif;
}

.upload-subtitle {
  font-size: 26rpx;
  color: #9B7653;
  letter-spacing: 0.5rpx;
}

/* 拍照次数提示 */
.scan-count-tip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 20rpx;
  padding: 10rpx 24rpx;
  background: rgba(232, 144, 66, 0.12);
  border-radius: 100rpx;
  border: 1.5rpx solid rgba(232, 144, 66, 0.25);
}

.scan-count-icon {
  width: 28rpx;
  height: 28rpx;
}

.scan-count-text {
  font-size: 22rpx;
  color: #C4703C;
  font-weight: 500;
}

/* --- 操作按钮组 --- */
.action-group {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 1;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow:
    0 4rpx 20rpx rgba(160, 100, 40, 0.1),
    0 1rpx 4rpx rgba(160, 100, 40, 0.06);
  border: 1.5rpx solid rgba(200, 160, 100, 0.18);
  transition: all 0.2s ease;
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(160, 100, 40, 0.08);
}

.action-btn--primary {
  background: linear-gradient(135deg, #E8924A 0%, #D47030 100%);
  border-color: transparent;
  box-shadow:
    0 8rpx 32rpx rgba(232, 144, 66, 0.3),
    0 2rpx 8rpx rgba(200, 100, 40, 0.15);
}

.action-btn--primary:active {
  box-shadow: 0 4rpx 16rpx rgba(232, 144, 66, 0.2);
}

.action-btn-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: rgba(232, 144, 66, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.action-btn--primary .action-btn-icon {
  background: rgba(255, 255, 255, 0.2);
}

.icon-camera {
  width: 54rpx;
  height: 54rpx;
  display: block;
}

.icon-album {
  width: 46rpx;
  height: 46rpx;
  display: block;
}

.action-btn-text {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.action-btn-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #4A2C0E;
  letter-spacing: 1rpx;
}

.action-btn--primary .action-btn-title {
  color: #FFFFFF;
}

.action-btn-sub {
  font-size: 22rpx;
  color: #9B7653;
}

.action-btn--primary .action-btn-sub {
  color: rgba(255, 255, 255, 0.75);
}

.action-btn-arrow {
  font-size: 48rpx;
  color: #C8A080;
  font-weight: 300;
  line-height: 1;
}

.action-btn--primary .action-btn-arrow {
  color: rgba(255, 255, 255, 0.7);
}

/* --- 底部提示 --- */
.upload-footer {
  margin-top: auto;
}

.footer-text {
  font-size: 24rpx;
  color: #C8A080;
  text-align: center;
  letter-spacing: 0.5rpx;
}

/* ============================================
   第二步：识别中
   ============================================ */

.recognizing-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 48rpx;
  background: #FFF8EE;
}

/* --- 砂锅插画 --- */
.pot-wrap {
  position: relative;
  width: 240rpx;
  height: 280rpx;
  margin-bottom: 60rpx;
}

.pot {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 200rpx;
  height: 160rpx;
}

/* 锅身 */
.pot-body {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 130rpx;
  background: linear-gradient(160deg, #C45520, #A03D18, #8B3210);
  border-radius: 8rpx 8rpx 40% 40% / 8rpx 8rpx 50% 50%;
  box-shadow:
    inset -12rpx -12rpx 24rpx rgba(0, 0, 0, 0.2),
    inset 4rpx 4rpx 8rpx rgba(255, 180, 120, 0.15),
    0 8rpx 32rpx rgba(140, 50, 20, 0.3);
}

/* 锅沿 */
.pot-rim {
  position: absolute;
  top: 28rpx;
  left: -8rpx;
  right: -8rpx;
  height: 22rpx;
  background: linear-gradient(to bottom, #D4622A, #B84E20);
  border-radius: 50%;
  box-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.15);
}

/* 锅柄 */
.pot-handle {
  position: absolute;
  top: 30rpx;
  width: 36rpx;
  height: 20rpx;
  background: #8B3210;
  border-radius: 10rpx;
}
.pot-handle--left  { left: -40rpx; }
.pot-handle--right { right: -40rpx; }

/* 锅内汤面 */
.pot-soup {
  position: absolute;
  top: 44rpx;
  left: 8rpx;
  right: 8rpx;
  height: 24rpx;
  background: linear-gradient(to bottom, #C8752A, #B06020);
  border-radius: 50%;
}

/* 锅内食材 */
.pot-ingredient {
  position: absolute;
  border-radius: 50%;
}
.pot-ingredient--1 {
  width: 28rpx;
  height: 28rpx;
  background: radial-gradient(ellipse at 35% 35%, #FF7B5C, #E84040);
  top: 50rpx;
  left: 36rpx;
  animation: bubbleUp 2s ease-in-out infinite;
}
.pot-ingredient--2 {
  width: 20rpx;
  height: 20rpx;
  background: #F5E0B8;
  top: 46rpx;
  right: 40rpx;
  animation: bubbleUp 2s ease-in-out infinite 0.7s;
}
.pot-ingredient--3 {
  width: 24rpx;
  height: 24rpx;
  background: #66BB6A;
  top: 56rpx;
  left: 50%;
  transform: translateX(-50%);
  animation: bubbleUp 2s ease-in-out infinite 1.3s;
}

@keyframes bubbleUp {
  0%, 100% { transform: translateY(0); opacity: 0.9; }
  50%       { transform: translateY(-6rpx); opacity: 1; }
}

/* 蒸汽 */
.steam-group {
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 80rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 16rpx;
}

.steam {
  width: 18rpx;
  border-radius: 50%;
  background: rgba(200, 160, 100, 0.35);
  animation: steamRise ease-in-out infinite;
}
.steam--1 {
  height: 50rpx;
  animation-duration: 2s;
  animation-delay: 0s;
}
.steam--2 {
  height: 68rpx;
  animation-duration: 2s;
  animation-delay: 0.4s;
}
.steam--3 {
  height: 44rpx;
  animation-duration: 2s;
  animation-delay: 0.8s;
}

@keyframes steamRise {
  0%   { transform: translateY(0) scaleX(1); opacity: 0.6; }
  50%  { transform: translateY(-20rpx) scaleX(1.4); opacity: 0.3; }
  100% { transform: translateY(-40rpx) scaleX(0.8); opacity: 0; }
}

/* 识别状态文字 */
.rec-badge {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 8rpx 24rpx;
  background: rgba(232, 144, 66, 0.1);
  border: 1.5rpx solid rgba(232, 144, 66, 0.28);
  border-radius: 100rpx;
  margin-bottom: 24rpx;
}

.rec-dot {
  width: 8rpx;
  height: 8rpx;
  background: #E8924A;
  border-radius: 50%;
  animation: dotPulse 1s ease-in-out infinite;
}

@keyframes dotPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.4; transform: scale(0.7); }
}

.rec-badge-text {
  font-size: 22rpx;
  color: #E8924A;
  font-weight: 600;
}

.rec-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #4A2C0E;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.rec-sub {
  font-size: 26rpx;
  color: #9B7653;
  margin-bottom: 48rpx;
}

/* 进度条 */
.rec-progress-bar {
  width: 480rpx;
  height: 8rpx;
  background: rgba(200, 160, 100, 0.15);
  border-radius: 4rpx;
  overflow: hidden;
}

.rec-progress-fill {
  height: 100%;
  width: 40%;
  background: linear-gradient(90deg, #E8924A, #F0A060);
  border-radius: 4rpx;
  animation: progressScan 2.2s ease-in-out infinite;
}

@keyframes progressScan {
  0%   { width: 5%;  margin-left: 0; }
  50%  { width: 60%; margin-left: 0; }
  100% { width: 5%;  margin-left: 95%; }
}

/* ============================================
   第三步：识别结果
   ============================================ */

/* --- 顶部图片预览 --- */
.result-header {
  background: #FFF3E0;
  border-bottom: 1rpx solid rgba(200, 140, 80, 0.15);
}

.result-img-scroll {
  padding: 24rpx 24rpx 16rpx;
  white-space: nowrap;
}

.result-img-list {
  display: inline-flex;
  gap: 16rpx;
  align-items: center;
}

.result-img-item {
  position: relative;
  flex-shrink: 0;
  width: 168rpx;
  height: 168rpx;
  border-radius: 16rpx;
  overflow: hidden;
  border: 3rpx solid rgba(232, 144, 66, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(160, 100, 40, 0.12);
}

.result-img {
  width: 100%;
  height: 100%;
}

.result-img-remove {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #E8924A;
  font-size: 28rpx;
  font-weight: 300;
  line-height: 1;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.12);
}

.result-retake {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: 0 24rpx 16rpx;
  font-size: 24rpx;
  color: #E8924A;
  font-weight: 600;
}

/* --- 食材区 --- */
.result-body {
  flex: 1;
  padding: 24rpx 24rpx 0;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  background: #FFF8EE;
}

/* 统计卡片 */
.result-stat-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  box-shadow:
    0 4rpx 20rpx rgba(160, 100, 40, 0.08),
    0 1rpx 4rpx rgba(160, 100, 40, 0.05);
  border: 1.5rpx solid rgba(200, 160, 100, 0.15);
}

.stat-card-left {
  display: flex;
  align-items: center;
}

.stat-card-title {
  font-size: 28rpx;
  color: #4A2C0E;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.stat-card-divider {
  width: 1.5rpx;
  height: 36rpx;
  background: rgba(200, 160, 100, 0.2);
  margin: 0 20rpx;
}

.stat-card-right {
  display: flex;
  align-items: center;
}

.stat-count-wrap {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  padding: 6rpx 16rpx;
  background: linear-gradient(135deg, rgba(232, 144, 66, 0.1), rgba(212, 112, 48, 0.08));
  border-radius: 100rpx;
  border: 1.5rpx solid rgba(232, 144, 66, 0.25);
}

.stat-count-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #E8924A;
}

.stat-count-unit {
  font-size: 20rpx;
  color: rgba(232, 144, 66, 0.7);
}

/* 食材标签区 */
.tags-zone {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  padding-bottom: 160rpx;
}

/* 木质吊牌 */
.wood-tag {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx 20rpx;
  min-width: 120rpx;
  background: linear-gradient(160deg, #E8C89A 0%, #D4AE7A 50%, #C09860 100%);
  border-radius: 12rpx;
  box-shadow:
    0 6rpx 20rpx rgba(160, 100, 40, 0.22),
    0 2rpx 6rpx rgba(160, 100, 40, 0.1),
    inset 0 1rpx 0 rgba(255, 220, 160, 0.4);
  border: 1rpx solid rgba(160, 100, 40, 0.2);
  transition: all 0.15s ease;
}

.wood-tag::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 12rpx;
  background-image: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 18rpx,
    rgba(0, 0, 0, 0.025) 18rpx,
    rgba(0, 0, 0, 0.025) 19rpx
  );
  pointer-events: none;
}

.wood-tag:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(160, 100, 40, 0.15);
}

/* 绳孔和绳子 */
.tag-hole {
  width: 12rpx;
  height: 12rpx;
  background: rgba(160, 100, 40, 0.3);
  border-radius: 50%;
  margin-bottom: 4rpx;
  position: relative;
}

.tag-string {
  position: absolute;
  top: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 3rpx;
  height: 12rpx;
  background: #A07840;
  border-radius: 2rpx;
}

.tag-text {
  font-size: 26rpx;
  color: #4A2C0E;
  font-weight: 600;
  letter-spacing: 0.5rpx;
  text-align: center;
}

.tag-x {
  font-size: 22rpx;
  color: rgba(74, 44, 14, 0.4);
  margin-top: 2rpx;
}

/* 添加标签 */
.wood-tag--add {
  background: transparent;
  border: 2rpx dashed rgba(200, 140, 80, 0.4);
  box-shadow: none;
  padding: 16rpx 20rpx 16rpx;
  min-width: 100rpx;
}
.wood-tag--add::before { display: none; }
.wood-tag--add .tag-hole { background: transparent; border: 2rpx dashed rgba(200, 140, 80, 0.4); width: 14rpx; height: 14rpx; }
.wood-tag--add .tag-string { display: none; }
.wood-tag--add .tag-text { color: #C87840; font-size: 26rpx; }
.wood-tag--add .tag-x { display: none; }

/* 空状态 */
.tags-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  gap: 16rpx;
}

.tags-empty-icon {
  font-size: 56rpx;
  color: rgba(200, 140, 80, 0.25);
}

.tags-empty-text {
  font-size: 26rpx;
  color: rgba(155, 118, 83, 0.6);
  text-align: center;
  padding: 0 40rpx;
  line-height: 1.6;
}

/* --- 底部生成按钮 --- */
.result-footer {
  padding: 20rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #FFF8EE 50%, transparent);
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.gen-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 100rpx;
  background: rgba(200, 160, 100, 0.12);
  border: 2rpx solid rgba(200, 160, 100, 0.2);
  border-radius: 50rpx;
  transition: all 0.25s ease;
}

.gen-btn--active {
  background: linear-gradient(135deg, #E8924A 0%, #D47030 100%);
  border-color: transparent;
  box-shadow: 0 10rpx 40rpx rgba(232, 144, 66, 0.32);
}

.gen-btn--hover {
  opacity: 0.92;
  transform: scale(0.98);
}

.gen-btn-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 3rpx;
}

.gen-btn-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 300;
  line-height: 1;
}

.gen-btn-text-off {
  font-size: 28rpx;
  color: rgba(155, 118, 83, 0.5);
  font-weight: 400;
  letter-spacing: 1rpx;
}

/* ============================================
   添加食材弹窗
   ============================================ */

.add-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 900;
}

.add-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #FFF8EE;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0 0 calc(env(safe-area-inset-bottom) + 32rpx);
  z-index: 901;
  animation: panelSlideUp 0.28s cubic-bezier(0.34, 1.56, 0.64, 1);
  border-top: 1rpx solid rgba(200, 160, 100, 0.15);
}

@keyframes panelSlideUp {
  from { transform: translateY(100%); }
  to   { transform: translateY(0); }
}

.panel-head {
  padding: 16rpx 28rpx 0;
}

.panel-handle-bar {
  width: 72rpx;
  height: 6rpx;
  background: rgba(200, 160, 100, 0.25);
  border-radius: 3rpx;
  margin: 0 auto 20rpx;
}

.panel-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(200, 160, 100, 0.12);
}

.panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #4A2C0E;
  letter-spacing: 1rpx;
}

.panel-close-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: rgba(155, 118, 83, 0.5);
  font-weight: 300;
  border-radius: 50%;
  background: rgba(200, 160, 100, 0.08);
}

.panel-search-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin: 20rpx 24rpx 0;
  padding: 22rpx 24rpx;
  background: #FFFFFF;
  border: 1.5rpx solid rgba(200, 160, 100, 0.2);
  border-radius: 18rpx;
  box-shadow: 0 2rpx 10rpx rgba(160, 100, 40, 0.06);
}

.panel-search-icon {
  font-size: 28rpx;
  color: rgba(200, 140, 80, 0.5);
  flex-shrink: 0;
}

.panel-input {
  flex: 1;
  font-size: 30rpx;
  color: #4A2C0E;
  background: transparent;
}

.panel-placeholder {
  color: rgba(155, 118, 83, 0.45);
}

.suggestions {
  max-height: 480rpx;
  margin: 12rpx 24rpx 0;
}

.suggestion-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 26rpx 4rpx;
  border-bottom: 1rpx solid rgba(200, 160, 100, 0.08);
  transition: background 0.12s;
}

.suggestion-item:last-child { border-bottom: none; }
.suggestion-item:active { background: rgba(200, 160, 100, 0.05); }

.suggestion-dot {
  width: 8rpx;
  height: 8rpx;
  background: #E8924A;
  border-radius: 50%;
  flex-shrink: 0;
}

.suggestion-name {
  font-size: 30rpx;
  color: #4A2C0E;
}

.panel-tip {
  text-align: center;
  font-size: 24rpx;
  color: rgba(155, 118, 83, 0.45);
  padding: 32rpx 0;
}

/* ============================================
   食材名称映射面板
   ============================================ */

.mapping-source-wrap {
  display: flex;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 20rpx 24rpx 0;
  margin-bottom: 8rpx;
}

.mapping-source-label {
  font-size: 26rpx;
  color: #9B7653;
  flex-shrink: 0;
}

.mapping-source-name {
  font-size: 28rpx;
  color: #E8924A;
  font-weight: 600;
  background: rgba(232, 144, 66, 0.1);
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
}

.mapping-source-tip {
  font-size: 22rpx;
  color: rgba(155, 118, 83, 0.6);
  width: 100%;
}

.suggestion-category {
  margin-left: auto;
  font-size: 22rpx;
  color: rgba(155, 118, 83, 0.5);
  flex-shrink: 0;
}

.mapping-skip-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 16rpx 24rpx 0;
  padding: 20rpx;
  font-size: 26rpx;
  color: rgba(155, 118, 83, 0.55);
  text-decoration: underline;
}

/* ============================================
   图片模糊提示
   ============================================ */

.blur-tip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 24rpx 16rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
  border: 1rpx solid rgba(255, 152, 0, 0.25);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 152, 0, 0.1);
}

.blur-tip-icon {
  width: 48rpx;
  height: 48rpx;
  flex-shrink: 0;
}

.blur-tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.blur-tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #E65100;
}

.blur-tip-desc {
  font-size: 24rpx;
  color: #BF360C;
  opacity: 0.85;
  line-height: 1.5;
}

.blur-tip-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: rgba(255, 152, 0, 0.6);
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(255, 152, 0, 0.08);
}

.blur-tip-close:active {
  background: rgba(255, 152, 0, 0.15);
}

