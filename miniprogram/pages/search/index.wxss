.page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  box-sizing: border-box;
}

.toolbar {
  flex-shrink: 0;
  padding: 16rpx 24rpx 20rpx;
  background: rgba(255, 255, 255, 0.88);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.06);
}

.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.input-shell {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f2f2f7;
  border-radius: 16rpx;
}

.input-shell__icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  opacity: 0.55;
}

.input-shell__field {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 28rpx;
  color: #1c1c1e;
}

.input-shell__ph {
  color: #aeaeb2;
  font-size: 28rpx;
}

.input-shell__clear {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.input-shell__clear-x {
  font-size: 36rpx;
  color: #c7c7cc;
  line-height: 1;
}

.search-action {
  flex-shrink: 0;
  font-size: 30rpx;
  color: #e2a650;
  color: var(--primary, #e2a650);
  font-weight: 600;
  padding: 12rpx 4rpx;
}

.panel {
  flex: 1;
  height: 0;
  min-height: 0;
}

.main-scroll {
  padding: 8rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.block {
  margin-top: 28rpx;
}

.block__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.block__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.block__action {
  font-size: 26rpx;
  color: #8e8e93;
}

.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 14rpx 24rpx;
  background: #f2f2f7;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #3a3a3c;
  max-width: 100%;
}

.hint-muted {
  font-size: 26rpx;
  color: #aeaeb2;
}

.suggest-list {
  background: #ffffff;
}

.suggest-item {
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f2f2f7;
}

.suggest-item:active {
  background: #f9f9f9;
}

.suggest-item__text {
  font-size: 30rpx;
  color: #1c1c1e;
}

.suggest-empty {
  padding: 80rpx 32rpx;
  text-align: center;
  font-size: 28rpx;
  color: #8e8e93;
}
