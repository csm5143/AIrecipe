/** custom/index.wxss **/
/** 定制主页：小菜篮 + 横向菜单卡片流 + 健身减脂餐 + 儿童营养餐 + 一日菜谱规划 **/

.page {
  height: 100vh;
  overflow: hidden;
  background: #f5f5f7;
}

.page-scroll {
  height: 100vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
}

.content {
  padding: 0 32rpx 120rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 页面标题 */
.header {
  padding: 40rpx 0 32rpx;
}

.header .title {
  font-size: 48rpx;
  font-weight: 800;
  color: #111111;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
  line-height: 1.2;
}

.header .subtitle {
  font-size: 28rpx;
  color: #8e8e93;
}

/* 小菜篮入口 */
.basket-card {
  display: flex;
  align-items: center;
  background: #fffdf8;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: opacity 0.15s;
}

.basket-card:active {
  opacity: 0.88;
}

.basket-card-left {
  margin-right: 20rpx;
  flex-shrink: 0;
}

.basket-icon {
  width: 88rpx;
  height: 88rpx;
}

.basket-card-body {
  flex: 1;
  min-width: 0;
}

.basket-card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 8rpx;
}

.basket-card-desc {
  font-size: 26rpx;
  color: #8e8e93;
}

.basket-card-desc--empty {
  color: #aeaeb2;
  font-size: 24rpx;
}

.basket-card-arrow {
  font-size: 48rpx;
  color: #d1d1d6;
  font-weight: 300;
  flex-shrink: 0;
  line-height: 1;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 24rpx;
}

/* 横向菜单卡片流 */
.menu-stream-section {
  margin-bottom: 40rpx;
}

.menu-scroll {
  white-space: nowrap;
  overflow: hidden;
}

.menu-track {
  display: inline-flex;
  align-items: flex-start;
  padding-bottom: 8rpx;
}

.menu-card-wrap {
  display: inline-block;
  width: 293rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.menu-card {
  width: 100%;
  height: 390rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.menu-card-cover {
  width: 100%;
  height: 315rpx;
  display: block;
}

.menu-card-tag {
  position: absolute;
  left: 14rpx;
  top: 14rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.menu-card-tag__title {
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
}

.menu-card-tag__extra {
  font-size: 22rpx;
  color: #ffffff;
  font-weight: 600;
  margin-left: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
  background: rgba(255, 255, 255, 0.9);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  color: #333;
}

.menu-card-footer {
  height: 75rpx;
  padding: 0 14rpx;
  box-sizing: border-box;
  background: rgba(40, 40, 45, 0.80);
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-card-desc {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 500;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 健身减脂餐入口 */
.fitness-banner {
  position: relative;
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(90, 160, 120, 0.15);
  margin-top: 24rpx;
}

.fitness-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  filter: blur(0rpx) brightness(1.1);
  transform: scale(1.1);
}

.fitness-overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(255, 255, 255, 0.25);
}

.fitness-content {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-60%);
  text-align: center;
  padding: 0 40rpx;
}

.fitness-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.fitness-subtitle {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.95);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 1rpx;
}

.fitness-action {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #5a9e78;
  font-weight: 600;
}

.fitness-arrow {
  margin-left: 8rpx;
  font-weight: 700;
}

/* 儿童营养餐入口 */
.kids-banner {
  position: relative;
  width: 100%;
  height: 340rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(200, 160, 120, 0.2);
}

.kids-bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  filter: blur(1rpx) brightness(1.1);
}

.kids-content {
  position: absolute;
  left: 0;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  text-align: center;
  padding: 0 40rpx;
}

.kids-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 4rpx 16rpx rgba(139, 90, 43, 0.6);
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.kids-subtitle {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255, 248, 235, 0.95);
  text-shadow: 0 2rpx 8rpx rgba(139, 90, 43, 0.4);
  letter-spacing: 1rpx;
}

.kids-decor {
  position: absolute;
  top: 20rpx;
  right: 24rpx;
  font-size: 36rpx;
  opacity: 0.7;
}

.kids-star {
  color: #fff7d6;
  text-shadow: 0 2rpx 8rpx rgba(200, 160, 100, 0.5);
}

.kids-action {
  position: absolute;
  right: 28rpx;
  bottom: 28rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 248, 235, 0.92);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #c4875a;
  font-weight: 600;
}

.kids-arrow {
  margin-left: 8rpx;
  font-weight: 700;
}

