.page {
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #fef8f0 0%, #f5f5f7 300rpx);
}

.page-scroll {
  height: 100vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  overscroll-behavior: contain;
}

.content {
  padding: 32rpx 24rpx 120rpx;
}

/* 封面区 */
.cover-section {
  margin-bottom: 32rpx;
}

.cover-preview {
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto;
  border-radius: 24rpx;
  overflow: hidden;
  background-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}

.preview-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.preview-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f8f8f8 0%, #e8e8e8 100%);
}

.preview-icon {
  font-size: 72rpx;
  margin-bottom: 8rpx;
}

.preview-text {
  font-size: 24rpx;
  color: #8e8e93;
}

/* 表单区 */
.form-section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
  position: relative;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #3c3c43;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  background-color: #f5f5f7;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
  color: #111111;
}

.form-input:focus {
  background-color: #efefef;
  outline: none;
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  background-color: #f5f5f7;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #111111;
}

.form-textarea:focus {
  background-color: #efefef;
  outline: none;
}

.form-hint {
  position: absolute;
  right: 4rpx;
  bottom: -28rpx;
  font-size: 24rpx;
  color: #8e8e93;
}

/* 统计区 */
.stats-section {
  display: flex;
  justify-content: space-around;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  color: #E2A650;
  font-weight: 700;
}

.stat-label {
  font-size: 24rpx;
  color: #8e8e93;
}

/* 保存按钮 */
.save-section {
  margin-bottom: 24rpx;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background-color: #d1d1d6;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.save-btn.active {
  background: linear-gradient(135deg, #E2A650 0%, #f5c086 100%);
  box-shadow: 0 8rpx 24rpx rgba(226, 166, 80, 0.4);
}

.save-btn:active {
  transform: scale(0.98);
}

/* 删除按钮 */
.danger-section {
  margin-top: 24rpx;
}

.delete-btn {
  width: 100%;
  height: 96rpx;
  background-color: #ffffff;
  color: #ff3b30;
  font-size: 30rpx;
  font-weight: 600;
  border: 2rpx solid #ff3b30;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-btn:active {
  background-color: #fff5f5;
}
