/* ==============================
   每日推荐 — 与小程序主题统一（暖米白 + 蜂蜜杏）
   ============================== */

/* ---------- 页面基础 ---------- */
.page {
  min-height: 100vh;
  background: #fbf4e6;
}

/* ==============================
   Banner 区
   ============================== */
.banner {
  position: relative;
  width: 100%;
  height: 520rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.banner:active {
  opacity: 0.96;
}

/* 全宽美食大图 */
.banner__bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

/* 整体暗化 10%（通过叠加半透明黑色层实现） */
.banner__overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.1);
}

/* 左上角白色返回箭头（毛玻璃胶囊） */
.banner__back {
  position: absolute;
  top: 80rpx;
  left: 32rpx;
  z-index: 10;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  display: flex;
  align-items: center;
  justify-content: center;
}

.banner__back:active {
  background: rgba(255, 255, 255, 0.5);
}

.banner__back-arrow {
  font-size: 48rpx;
  color: #ffffff;
  line-height: 1;
  font-weight: 300;
  margin-left: -2rpx;
}

/* 标签区（右下角毛玻璃胶囊） */
.banner__badge-wrap {
  position: absolute;
  bottom: 36rpx;
  right: 28rpx;
  z-index: 10;
}

.banner__badge {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.28);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  font-size: 24rpx;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 2rpx;
}

/* 底部渐变（文字衬底） */
.banner__gradient {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  background: linear-gradient(to top, rgba(10, 10, 10, 0.5) 0%, transparent 100%);
  pointer-events: none;
  z-index: 4;
}

/* ==============================
   菜品列表区（左图右文纵向列表）
   ============================== */
.list-area {
  padding: 28rpx 28rpx 140rpx;
}

/* 列表标题栏 */
.list-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.list-header__title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2d241b;
}

.list-header__count {
  font-size: 24rpx;
  color: #7a6a58;
}

/* 单个菜品卡片（白底卡片，圆角，无分割线） */
.list-card {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background: #fffdf8;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(125, 90, 50, 0.08);
}

.list-card:last-of-type {
  margin-bottom: 0;
}

.list-card:active {
  opacity: 0.88;
  transform: scale(0.98);
}

/* 左侧：正方形封面图，圆角 12rpx */
.list-card__img-wrap {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  border-radius: 12rpx;
  overflow: hidden;
  background: #f6e8d6;
  margin-right: 20rpx;
}

.list-card__img {
  width: 100%;
  height: 100%;
}

/* 中间：文字区域（垂直排列） */
.list-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}

/* 菜品标题：大号深色加粗字体 */
.list-card__name {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d241b;
  line-height: 1.3;
  letter-spacing: 0.5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

/* 菜品描述：小号灰色，超长省略 */
.list-card__desc {
  font-size: 24rpx;
  color: #8a7c6e;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

/* 右侧箭头 */
.list-card__arrow {
  flex-shrink: 0;
  padding-left: 12rpx;
}

.list-card__arrow text {
  font-size: 36rpx;
  color: #c9b99a;
  font-weight: 300;
}

/* 底部提示 */
.list-footer {
  text-align: center;
  padding: 40rpx 0 20rpx;
}

.list-footer text {
  font-size: 22rpx;
  color: #c9b99a;
  letter-spacing: 1rpx;
}

/* ==============================
   空状态
   ============================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
  gap: 16rpx;
}

.empty-state__text {
  font-size: 28rpx;
  color: #7a6a58;
  text-align: center;
  line-height: 1.8;
}
