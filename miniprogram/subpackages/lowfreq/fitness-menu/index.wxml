<view class="page">
  <scroll-view class="page-scroll" scroll-y enhanced bounces="{{true}}">

    <!-- 顶部概览卡片：已保存定制方案时显示 -->
    <view class="overview-card" wx:if="{{hasSettings}}">
      <view class="overview-header">
        <view class="overview-title">
          <image class="overview-icon" src="{{overviewGoalIcon}}" mode="aspectFit" />
          <view class="overview-title-text">
            <text class="overview-goal">{{fitnessGoal.goalLabel}}专属方案</text>
            <text class="overview-subtitle">{{mealTimesLabel}}</text>
          </view>
        </view>
        <view class="overview-edit" bindtap="onEditSettings" hover-class="overview-edit--hover">
          <image src="/assets/更多.png" mode="aspectFit" class="edit-icon" />
          <text class="edit-text">修改</text>
        </view>
      </view>
      <view class="overview-tags">
        <view class="overview-tag overview-tag--safe" wx:if="{{excludedAllergies.length === 0}}">
          <image src="/assets/通过.png" mode="aspectFit" class="tag-icon" />
          <text>无过敏</text>
        </view>
        <view class="overview-tag overview-tag--warning" wx:if="{{excludedAllergies.length > 0}}">
          <image src="/assets/不要.png" mode="aspectFit" class="tag-icon" />
          <text>已排除{{excludedAllergies.length}}种过敏原</text>
        </view>
      </view>
    </view>

    <!-- 今日健身餐推荐 -->
    <view class="meals-section" wx:if="{{currentMeal}}">
      <view class="section-header">
        <view class="section-title-row">
          <text class="section-title">今日健身餐推荐</text>
          <view class="refresh-btn" bindtap="onRefreshBatch" hover-class="refresh-btn--hover">
            <image class="refresh-icon" src="/assets/更换.png" mode="aspectFit" />
            <text class="refresh-text">换一批</text>
          </view>
        </view>
        <text class="section-sub">{{goalStrategyLine}}</text>
      </view>

      <!-- 早/午/晚餐切换 -->
      <view class="meal-tabs">
        <view
          wx:if="{{showTabBreakfast}}"
          class="meal-tab {{mealTabKey === 'breakfast' ? 'meal-tab--active' : ''}}"
          bindtap="onMealTabTap"
          data-key="breakfast"
        >
          <text>早餐</text>
          <view class="meal-tab-line" wx:if="{{mealTabKey === 'breakfast'}}"></view>
        </view>
        <view
          wx:if="{{showTabLunch}}"
          class="meal-tab {{mealTabKey === 'lunch' ? 'meal-tab--active' : ''}}"
          bindtap="onMealTabTap"
          data-key="lunch"
        >
          <text>午餐</text>
          <view class="meal-tab-line" wx:if="{{mealTabKey === 'lunch'}}"></view>
        </view>
        <view
          wx:if="{{showTabDinner}}"
          class="meal-tab {{mealTabKey === 'dinner' ? 'meal-tab--active' : ''}}"
          bindtap="onMealTabTap"
          data-key="dinner"
        >
          <text>晚餐</text>
          <view class="meal-tab-line" wx:if="{{mealTabKey === 'dinner'}}"></view>
        </view>
      </view>

      <!-- 整餐总览摘要 -->
      <view class="meal-summary">
        <view class="meal-summary__left">
          <view class="meal-summary__badge-row">
            <text class="meal-summary__badge">{{currentMeal.goalBadge}}</text>
            <text class="meal-summary__meal-name">{{currentMeal.mealTimeLabel}}</text>
          </view>
        </view>
        <text class="meal-summary__count">{{currentMeal.dishes.length}}道菜</text>
      </view>

      <!-- 碳水区 -->
      <view class="nutrient-section" wx:if="{{showCarbs}}">
        <view class="nutrient-section__header">
          <view class="nutrient-section__dot" style="background:#333333"></view>
          <text class="nutrient-section__label">碳水</text>
          <text class="nutrient-section__sub">能量供给</text>
        </view>
        <view
          class="dish-card"
          wx:for="{{currentMealCarbs}}"
          wx:for-item="dish"
          wx:key="id"
          data-id="{{dish.id}}"
          data-name="{{dish.name}}"
          bindtap="onDishTap"
          hover-class="dish-card--hover"
        >
          <view class="dish-card__stripe" style="background:#333333"></view>
          <view class="dish-card__cover" wx:if="{{dish.coverImage || dish.icon}}">
            <image
              class="dish-card__cover-img {{dish.coverImage ? 'dish-card__cover-img--full' : ''}}"
              src="{{dish.coverImage || dish.icon}}"
              mode="{{dish.coverImage ? 'aspectFill' : 'aspectFit'}}"
              binderror="onCoverImgError"
              data-index="{{index}}"
            />
          </view>
          <view class="dish-card__body" style="{{(dish.coverImage || dish.icon) ? '' : 'margin-left:0'}}">
            <text class="dish-card__name">{{dish.name}}</text>
            <text class="dish-card__usage">{{dish.usageDisplay || dish.description}}</text>
            <view class="dish-card__footer" wx:if="{{dish.macroHint}}">
              <text class="dish-card__macro-hint">{{dish.macroHint}}</text>
            </view>
          </view>
          <view class="dish-card__arrow">
            <image src="/assets/右箭头.png" mode="aspectFit" class="dish-card__arrow-icon" />
          </view>
        </view>
      </view>

      <!-- 蛋白质区 -->
      <view class="nutrient-section" wx:if="{{showProteins}}">
        <view class="nutrient-section__header">
          <view class="nutrient-section__dot" style="background:#555555"></view>
          <text class="nutrient-section__label">蛋白质</text>
          <text class="nutrient-section__sub">肌肉修复</text>
        </view>
        <view
          class="dish-card"
          wx:for="{{currentMealProteins}}"
          wx:for-item="dish"
          wx:key="id"
          data-id="{{dish.id}}"
          data-name="{{dish.name}}"
          bindtap="onDishTap"
          hover-class="dish-card--hover"
        >
          <view class="dish-card__stripe" style="background:#555555"></view>
          <view class="dish-card__cover" wx:if="{{dish.coverImage || dish.icon}}">
            <image
              class="dish-card__cover-img {{dish.coverImage ? 'dish-card__cover-img--full' : ''}}"
              src="{{dish.coverImage || dish.icon}}"
              mode="{{dish.coverImage ? 'aspectFill' : 'aspectFit'}}"
              binderror="onCoverImgError"
              data-index="{{index}}"
            />
          </view>
          <view class="dish-card__body" style="{{(dish.coverImage || dish.icon) ? '' : 'margin-left:0'}}">
            <text class="dish-card__name">{{dish.name}}</text>
            <text class="dish-card__usage">{{dish.usageDisplay || dish.description}}</text>
            <view class="dish-card__footer" wx:if="{{dish.macroHint}}">
              <text class="dish-card__macro-hint">{{dish.macroHint}}</text>
            </view>
          </view>
          <view class="dish-card__arrow">
            <image src="/assets/右箭头.png" mode="aspectFit" class="dish-card__arrow-icon" />
          </view>
        </view>
      </view>

      <!-- 蔬菜区 -->
      <view class="nutrient-section" wx:if="{{showVeggies}}">
        <view class="nutrient-section__header">
          <view class="nutrient-section__dot" style="background:#777777"></view>
          <text class="nutrient-section__label">蔬菜</text>
          <text class="nutrient-section__sub">膳食纤维</text>
        </view>
        <view
          class="dish-card"
          wx:for="{{currentMealVeggies}}"
          wx:for-item="dish"
          wx:key="id"
          data-id="{{dish.id}}"
          data-name="{{dish.name}}"
          bindtap="onDishTap"
          hover-class="dish-card--hover"
        >
          <view class="dish-card__stripe" style="background:#777777"></view>
          <view class="dish-card__cover" wx:if="{{dish.coverImage || dish.icon}}">
            <image
              class="dish-card__cover-img {{dish.coverImage ? 'dish-card__cover-img--full' : ''}}"
              src="{{dish.coverImage || dish.icon}}"
              mode="{{dish.coverImage ? 'aspectFill' : 'aspectFit'}}"
              binderror="onCoverImgError"
              data-index="{{index}}"
            />
          </view>
          <view class="dish-card__body" style="{{(dish.coverImage || dish.icon) ? '' : 'margin-left:0'}}">
            <text class="dish-card__name">{{dish.name}}</text>
            <text class="dish-card__usage">{{dish.usageDisplay || dish.description}}</text>
            <view class="dish-card__footer" wx:if="{{dish.macroHint}}">
              <text class="dish-card__macro-hint">{{dish.macroHint}}</text>
            </view>
          </view>
          <view class="dish-card__arrow">
            <image src="/assets/右箭头.png" mode="aspectFit" class="dish-card__arrow-icon" />
          </view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-hint" wx:if="{{!currentMeal}}">
        <text>该时段暂无符合条件的一餐，可在设置中勾选对应用餐时段</text>
      </view>
    </view>

    <!-- 今日营养要点 -->
    <view class="tips-card" wx:if="{{hasSettings}}">
      <view class="tips-header-row">
        <text class="tips-title">今日营养要点</text>
        <view class="tips-refresh" bindtap="onRefreshNutritionTips" hover-class="tips-refresh--hover">
          <image class="tips-refresh-icon" src="/assets/刷新.png" mode="aspectFit" />
        </view>
      </view>
      <view class="tips-list-vertical">
        <view class="tip-row" wx:for="{{nutritionTips}}" wx:key="label">
          <view class="tip-row__icon-wrap">
            <image class="tip-row__icon" src="{{item.icon}}" mode="aspectFit" />
          </view>
          <view class="tip-row__body">
            <view class="tip-row__title-line">
              <text class="tip-row__badge">{{item.highlight}}</text>
              <text class="tip-row__label">{{item.label}}</text>
            </view>
            <text class="tip-row__value">{{item.value}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 未设置 / 无匹配餐品 -->
    <view class="empty-state" wx:if="{{!hasSettings || !currentMeal}}">
      <image src="/assets/菜篮.png" mode="aspectFit" class="empty-icon" />
      <text class="empty-text" wx:if="{{!hasSettings}}">还没有设置健身目标</text>
      <text class="empty-text" wx:elif="{{!currentMeal}}">暂无可用健身餐方案</text>
      <text class="empty-subtext" wx:if="{{!hasSettings}}">完成一次定制后，下次从「定制」页将直接进入方案</text>
      <text class="empty-subtext" wx:elif="{{!currentMeal}}">可在「修改」中调整过敏原或用餐时段</text>
      <view class="empty-btn" bindtap="onEditSettings">
        <text>{{hasSettings ? '去修改' : '去设置'}}</text>
      </view>
    </view>

  </scroll-view>
</view>
