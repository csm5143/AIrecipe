/** pages/custom/fitness-menu/index.wxss **/

/* =================== */
/* 基础布局             */
/* =================== */
.page {
  min-height: 100vh;
  background: #f5f5f7;
}

.page-scroll {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* =================== */
/* 顶部概览卡片         */
/* =================== */
.overview-card {
  margin: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.overview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.overview-title {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.overview-icon {
  width: 80rpx;
  height: 80rpx;
  flex-shrink: 0;
}

.overview-title-text {
  display: flex;
  flex-direction: column;
}

.overview-goal {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.overview-subtitle {
  font-size: 24rpx;
  color: #8e8e93;
  margin-top: 4rpx;
}

.overview-edit {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 20rpx 10rpx 14rpx;
  border: 1.5rpx solid #d1d1d6;
  border-radius: 50rpx;
  gap: 6rpx;
  flex-shrink: 0;
  box-sizing: border-box;
}

.overview-edit--hover {
  background: #f5f5f7;
  border-color: #aeaeb2;
}

.edit-icon {
  width: 32rpx;
  height: 32rpx;
}

.edit-text {
  font-size: 24rpx;
  color: #3c3c43;
  font-weight: 500;
  line-height: 1;
}

.overview-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.overview-tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #3c3c43;
}

.overview-tag--warning {
  background: rgba(0, 0, 0, 0.08);
  color: #555555;
}

.overview-tag--safe {
  background: rgba(0, 0, 0, 0.04);
  color: #333333;
}

.tag-icon {
  width: 26rpx;
  height: 26rpx;
}

/* =================== */
/* 健身餐推荐区域       */
/* =================== */
.meals-section {
  margin: 0 24rpx 24rpx;
  padding: 28rpx 24rpx 32rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.section-header {
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

.refresh-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 10rpx 20rpx 10rpx 14rpx;
  border: 1.5rpx solid #d1d1d6;
  border-radius: 50rpx;
  gap: 6rpx;
}

.refresh-btn--hover {
  background: #f5f5f7;
  border-color: #aeaeb2;
}

.refresh-icon {
  width: 32rpx;
  height: 32rpx;
}

.refresh-text {
  font-size: 24rpx;
  color: #3c3c43;
  font-weight: 500;
  line-height: 1;
}

.section-sub {
  display: block;
  font-size: 22rpx;
  color: #8e8e93;
  margin-top: 10rpx;
  line-height: 1.45;
}

/* =================== */
/* 早/午/晚餐标签       */
/* =================== */
.meal-tabs {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  margin-bottom: 28rpx;
  padding-bottom: 8rpx;
  border-bottom: 1rpx solid #ececec;
}

.meal-tab {
  position: relative;
  flex: 1;
  text-align: center;
  padding-bottom: 16rpx;
  font-size: 28rpx;
  color: #aeaeb2;
}

.meal-tab--active {
  color: #1a1a1a;
  font-weight: 600;
}

.meal-tab-line {
  position: absolute;
  left: 50%;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  margin-left: -24rpx;
  background: #1a1a1a;
  border-radius: 3rpx;
}

/* =================== */
/* 整餐总览摘要条       */
/* =================== */
.meal-summary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #f8f8f8, #f0f0f0);
  border-radius: 20rpx;
  border: 1rpx solid #d0d0d0;
}

.meal-summary__left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.meal-summary__badge-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.meal-summary__badge {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  background: #333333;
  border-radius: 8rpx;
  padding: 4rpx 14rpx;
  line-height: 1.2;
}

.meal-summary__meal-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.meal-summary__count {
  font-size: 22rpx;
  color: #888;
  background: #fff;
  border-radius: 20rpx;
  padding: 4rpx 16rpx;
  border: 1rpx solid #e0e0e0;
}

/* =================== */
/* 营养分区：碳水/蛋白/蔬菜 */
/* =================== */
.nutrient-section {
  margin-bottom: 28rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(180deg, #fafafa 0%, #f5f5f5 100%);
  border-radius: 20rpx;
  border: 1rpx solid #ececec;
}

.nutrient-section:last-child {
  margin-bottom: 0;
}

.nutrient-section__header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 0 4rpx;
}

.nutrient-section__dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.nutrient-section__label {
  font-size: 26rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 1rpx;
}

.nutrient-section__sub {
  font-size: 22rpx;
  color: #aeaeb2;
  font-weight: 400;
  margin-left: 4rpx;
}

/* =================== */
/* 单品大卡片           */
/* =================== */
.dish-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
  background: #fafafa;
  border-radius: 20rpx;
  border: 1rpx solid #ececec;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.03);
  box-sizing: border-box;
  overflow: hidden;
  position: relative;
}

.dish-card:last-child {
  margin-bottom: 0;
}

.dish-card--hover {
  background: #f0f0f5;
  border-color: #d0d0d5;
}

.dish-card__stripe {
  position: absolute;
  top: 0;
  left: 0;
  width: 6rpx;
  height: 100%;
  border-radius: 6rpx 0 0 6rpx;
}

.dish-card__cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 18rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  background: linear-gradient(145deg, #f0f0f0, #e8e8e8);
}

.dish-card__cover-img {
  width: 88rpx;
  height: 88rpx;
}

.dish-card__cover-img--full {
  width: 100%;
  height: 100%;
}

.dish-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.dish-card__name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-card__usage {
  font-size: 24rpx;
  color: #8e8e93;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dish-card__footer {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: auto;
  padding-top: 4rpx;
}

.dish-card__macro-hint {
  font-size: 24rpx;
  color: #5c6370;
  line-height: 1.35;
  background: #f3f4f6;
  border-radius: 10rpx;
  padding: 4rpx 14rpx;
}

.dish-card__arrow {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  opacity: 0.3;
}

.dish-card__arrow-icon {
  width: 30rpx;
  height: 30rpx;
}

/* =================== */
/* 空状态               */
/* =================== */
.empty-hint {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #aeaeb2;
  line-height: 1.6;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0 120rpx;
}

.empty-icon {
  width: 140rpx;
  height: 140rpx;
  opacity: 0.4;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #aeaeb2;
  margin-bottom: 32rpx;
}

.empty-btn {
  padding: 16rpx 48rpx;
  background: #1a1a1a;
  border-radius: 50rpx;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

/* =================== */
/* 营养小贴士           */
/* =================== */
.tips-card {
  margin: 0 24rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.tips-header-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.tips-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.tips-refresh {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  flex-shrink: 0;
}

.tips-refresh--hover {
  background: #f0f0f5;
}

.tips-refresh-icon {
  width: 40rpx;
  height: 40rpx;
}

.tips-list-vertical {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tip-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 20rpx;
  padding: 20rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.tip-row__icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  background: linear-gradient(145deg, #f0f0f0, #e0e0e0);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-row__icon {
  width: 48rpx;
  height: 48rpx;
}

.tip-row__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tip-row__title-line {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  align-items: center;
  gap: 12rpx;
}

.tip-row__badge {
  font-size: 22rpx;
  font-weight: 700;
  color: #333333;
  background: rgba(0, 0, 0, 0.08);
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  line-height: 1.2;
}

.tip-row__label {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
}

.tip-row__value {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}
