/** pages/custom/fitness/index.wxss **/
/** 白灰黑主色调 + 绿/橙色点缀 · 克制简约科技风 **/

.page {
  min-height: 100vh;
  background: #f5f5f7;
}

.page-scroll {
  min-height: 100vh;
}

/* ============================== */
/* 进度条                        */
/* ============================== */
.progress-bar {
  display: flex;
  align-items: center;
  padding: 40rpx 48rpx 36rpx;
  background: #ffffff;
  position: sticky;
  top: 0;
  z-index: 10;
}

.progress-step {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.step-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #e0e0e5;
  margin-bottom: 8rpx;
  transition: background 0.25s;
}

.progress-step.active .step-dot {
  background: #222222;
}

.progress-step.done .step-dot {
  background: #00C853;
}

.step-label {
  font-size: 20rpx;
  color: #c7c7cc;
  transition: color 0.25s;
}

.progress-step.active .step-label {
  color: #222222;
  font-weight: 600;
}

.progress-step.done .step-label {
  color: #00C853;
}

.progress-line {
  flex: 1;
  height: 2rpx;
  background: #e0e0e5;
  margin: 0 6rpx;
  margin-bottom: 18rpx;
  transition: background 0.25s;
}

.progress-line.active {
  background: #00C853;
}

/* ============================== */
/* Step 面板通用                 */
/* ============================== */
.step-panel {
  padding: 0 40rpx 120rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.step-header {
  margin-bottom: 40rpx;
}

.step-num {
  font-size: 64rpx;
  font-weight: 800;
  color: #f0f0f5;
  line-height: 1;
  margin-bottom: 8rpx;
  font-family: 'Avenir', 'Helvetica Neue', sans-serif;
  letter-spacing: -2rpx;
}

.step-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111111;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 26rpx;
  color: #8e8e93;
  line-height: 1.5;
}

.step-tip {
  margin-top: 32rpx;
  padding: 16rpx 20rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
}

.step-tip__text {
  font-size: 24rpx;
  color: #aeaeb2;
}

.step-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

/* ============================== */
/* 目标卡片列表                   */
/* ============================== */
.goal-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.goal-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #f0f0f5;
  transition: border-color 0.2s, box-shadow 0.2s;
  position: relative;
}

.goal-card--selected {
  border-color: #222222;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.goal-card:active {
  opacity: 0.88;
}

.goal-card__left {
  display: flex;
  align-items: center;
  flex: 1;
}

.goal-icon-img {
  width: 80rpx;
  height: 80rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.goal-card__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #111111;
  margin-bottom: 4rpx;
}

.goal-card__sub {
  font-size: 24rpx;
  color: #8e8e93;
}

.goal-card__check-img {
  position: absolute;
  top: 50%;
  right: 28rpx;
  width: 44rpx;
  height: 44rpx;
  margin-top: -22rpx;
  flex-shrink: 0;
}

/* ============================== */
/* 过敏原：胶囊文本               */
/* ============================== */
.allergy-pills {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 20rpx 16rpx;
}

.allergy-pill {
  padding: 18rpx 32rpx;
  background: #ffffff;
  border-radius: 999rpx;
  border: 4rpx solid #e8e8ec;
  box-sizing: border-box;
  transition: border-color 0.15s, transform 0.15s;
}

.allergy-pill:active {
  transform: scale(0.98);
}

.allergy-pill--selected {
  border-color: #111111;
}

.allergy-pill__text {
  font-size: 28rpx;
  font-weight: 500;
  color: #3c3c43;
}

.allergy-pill--selected .allergy-pill__text {
  font-weight: 700;
  color: #111111;
}

/* ============================== */
/* 用餐时段横向卡片               */
/* ============================== */
.meal-cards-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.meal-card {
  flex: 1;
  background: #ffffff;
  border: 4rpx solid #e8e8ec;
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  transition: border-color 0.18s, transform 0.18s, box-shadow 0.18s;
  position: relative;
}

.meal-card:active {
  transform: scale(0.97);
}

.meal-card--selected {
  border-color: #111111;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.meal-card__icon-img {
  width: 88rpx;
  height: 88rpx;
  margin-bottom: 12rpx;
}

.meal-card__name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.meal-hint {
  margin-bottom: 24rpx;
}

.meal-hint__text {
  font-size: 24rpx;
  color: #aeaeb2;
}

.meal-selected-hint {
  margin-bottom: 24rpx;
}

.meal-selected-hint__text {
  font-size: 24rpx;
  color: #3c3c43;
  font-weight: 500;
}

/* ============================== */
/* 底部按钮                       */
/* ============================== */
.step-btn {
  flex: 1;
  padding: 26rpx 0;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  transition: opacity 0.15s;
}

.step-btn:active {
  opacity: 0.85;
}

.step-btn--ghost {
  background: #ffffff;
  border: 2rpx solid #e0e0e5;
  color: #3c3c43;
  flex: 0 0 160rpx;
}

.step-btn--primary {
  background: #111111;
  color: #ffffff;
}
.step-btn--generate {
  background: #111111;
  color: #ffffff;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.18);
}
