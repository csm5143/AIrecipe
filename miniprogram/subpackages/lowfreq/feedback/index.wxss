.page {
  min-height: 100vh;
  background-color: #f5f5f7;
}

.page-scroll {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  padding-bottom: calc(120rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 区块 */
.section {
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.06);
}

/* 标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #111111;
}

.section-title-required {
  font-size: 28rpx;
  color: #ff3b30;
  margin-left: 8rpx;
}

.section-title-optional {
  font-size: 24rpx;
  color: #8e8e93;
  margin-left: 12rpx;
}

/* 问题类型标签 */
.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-item {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  background-color: #f5f5f7;
  border-radius: 40rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.type-item--active {
  background-color: #fff3e0;
  border-color: #ff9500;
}

.type-item-text {
  font-size: 26rpx;
  color: #3c3c43;
}

.type-item--active .type-item-text {
  color: #ff9500;
  font-weight: 600;
}

/* 多行文本框 */
.textarea-wrapper {
  position: relative;
}

.textarea {
  width: 100%;
  min-height: 240rpx;
  padding: 24rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #111111;
  line-height: 1.6;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.textarea:focus {
  border-color: #ff9500;
}

.textarea-placeholder {
  color: #c7c7cc;
}

.textarea-counter {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 22rpx;
  color: #c7c7cc;
}

/* 图片上传 */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-remove {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-remove image {
  width: 20rpx;
  height: 20rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  background-color: #f8f8f8;
  border-radius: 16rpx;
  border: 2rpx dashed #d1d1d6;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.image-add image {
  width: 56rpx;
  height: 56rpx;
}

.image-add-text {
  font-size: 22rpx;
  color: #8e8e93;
}

/* 输入框 */
.input-wrapper {
  background-color: #f8f8f8;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input-wrapper:focus-within {
  border-color: #ff9500;
}

.input {
  width: 100%;
  font-size: 28rpx;
  color: #111111;
}

.input-placeholder {
  color: #c7c7cc;
}

/* 提交按钮 */
.submit-section {
  margin-top: 48rpx;
  padding-bottom: 40rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #ff9500, #ff6a00);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  border: none;
  box-shadow: 0 12rpx 32rpx rgba(255, 149, 0, 0.3);
}

.submit-btn--disabled {
  background: linear-gradient(135deg, #d1d1d6, #c7c7cc);
  box-shadow: none;
}
