/* ========== 页面基础 ========== */
.page {
  min-height: 100vh;
  background: #f8f8f8;
}

/* ========== 顶部统计栏 ========== */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #ffffff;
  padding: 24rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
}

.header-left {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.header-count {
  font-size: 24rpx;
  color: #999999;
}

/* ========== 滚动区域 ========== */
.page-scroll {
  min-height: calc(100vh - 100rpx);
}

/* ========== 瀑布流容器 ========== */
.waterfall-container {
  display: flex;
  padding: 20rpx 16rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.waterfall-col {
  width: 50%;
  box-sizing: border-box;
}

.waterfall-col-left {
  padding-right: 8rpx;
}

.waterfall-col-right {
  padding-left: 8rpx;
}

/* ========== 瀑布流卡片 ========== */
.waterfall-item {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
}

/* 图片容器 */
.item-image-wrap {
  width: 100%;
  position: relative;
  overflow: hidden;
  background: #f0f0f0;
}

.item-image {
  width: 100%;
  display: block;
}

/* 卡路里标签 */
.item-calories {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(8rpx);
  -webkit-backdrop-filter: blur(8rpx);
  border-radius: 20rpx;
  padding: 6rpx 14rpx;
}

.item-calories text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 卡片内容 */
.item-content {
  padding: 16rpx;
}

.item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 1.4;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 元信息区域 */
.item-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 8rpx;
}

.item-time {
  display: inline-flex;
  align-items: center;
  background: #f5f5f5;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #666666;
}

.meta-icon {
  margin-right: 4rpx;
  font-size: 18rpx;
}

.item-difficulty {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #ffffff;
}

.item-difficulty.easy {
  background: #34c759;
}

.item-difficulty.normal {
  background: #ff9500;
}

.item-difficulty.hard {
  background: #ff3b30;
}

/* ========== 空状态 ========== */
.empty {
  margin-top: 200rpx;
  text-align: center;
}

.empty text {
  font-size: 28rpx;
  color: #999999;
}

/* ========== 底部提示 ========== */
.list-footer {
  text-align: center;
  padding: 40rpx 0;
}

.list-footer text {
  font-size: 24rpx;
  color: #cccccc;
}
