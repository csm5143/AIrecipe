<view class="page">
  <!-- WXML 不支持在 {{}} 里调用数组 .includes()，用 WXS 判断选中态 -->
  <wxs module="arrutils">
  function includes(arr, item) {
    if (!arr || arr.length === undefined) return false;
    var i = 0;
    for (i = 0; i < arr.length; i++) {
      if (arr[i] === item) return true;
    }
    return false;
  }
  module.exports.includes = includes;
  </wxs>
  <scroll-view class="page-scroll" scroll-y enhanced bounces="{{true}}">

    <!-- 顶部进度条 -->
    <view class="progress-bar">
      <view class="progress-step {{currentStep >= 1 ? 'active' : ''}} {{currentStep > 1 ? 'done' : ''}}">
        <view class="step-dot" />
        <view class="step-label">目标</view>
      </view>
      <view class="progress-line {{currentStep >= 2 ? 'active' : ''}}" />
      <view class="progress-step {{currentStep >= 2 ? 'active' : ''}}">
        <view class="step-dot" />
        <view class="step-label">过敏</view>
      </view>
      <view class="progress-line {{currentStep >= 3 ? 'active' : ''}}" />
      <view class="progress-step {{currentStep >= 3 ? 'active' : ''}}">
        <view class="step-dot" />
        <view class="step-label">时段</view>
      </view>
    </view>

    <!-- ============================== -->
    <!-- STEP 1：设定健身目标          -->
    <!-- ============================== -->
    <view class="step-panel" wx:if="{{currentStep === 1}}">
      <view class="step-header">
        <view class="step-num">01</view>
        <view class="step-title">设定你的健身目标</view>
        <view class="step-desc">不同的目标对应不同的营养配比和菜谱推荐</view>
      </view>

      <view class="goal-list">
        <view
          class="goal-card {{goal === 'lose' ? 'goal-card--selected' : ''}}"
          bindtap="onSelectGoal"
          data-goal="lose"
        >
          <view class="goal-card__left">
            <image class="goal-icon-img" src="/assets/运动减肥中.png" mode="aspectFit" />
            <view class="goal-card__info">
              <view class="goal-card__title">减脂</view>
              <view class="goal-card__sub">低脂肪 · 适量碳水</view>
            </view>
          </view>
          <image
            wx:if="{{goal === 'lose'}}"
            class="goal-card__check-img"
            src="/assets/选中.png"
            mode="aspectFit"
          />
        </view>

        <view
          class="goal-card {{goal === 'keep' ? 'goal-card--selected' : ''}}"
          bindtap="onSelectGoal"
          data-goal="keep"
        >
          <view class="goal-card__left">
            <image class="goal-icon-img" src="/assets/健身房.png" mode="aspectFit" />
            <view class="goal-card__info">
              <view class="goal-card__title">维持</view>
              <view class="goal-card__sub">均衡摄入 · 维持体型</view>
            </view>
          </view>
          <image
            wx:if="{{goal === 'keep'}}"
            class="goal-card__check-img"
            src="/assets/选中.png"
            mode="aspectFit"
          />
        </view>

        <view
          class="goal-card {{goal === 'gain' ? 'goal-card--selected' : ''}}"
          bindtap="onSelectGoal"
          data-goal="gain"
        >
          <view class="goal-card__left">
            <image class="goal-icon-img" src="/assets/健身.png" mode="aspectFit" />
            <view class="goal-card__info">
              <view class="goal-card__title">增肌</view>
              <view class="goal-card__sub">高蛋白 · 充足碳水</view>
            </view>
          </view>
          <image
            wx:if="{{goal === 'gain'}}"
            class="goal-card__check-img"
            src="/assets/选中.png"
            mode="aspectFit"
          />
        </view>
      </view>

      <view class="step-tip">
        <text class="step-tip__text">选择目标后，下一步将为你筛选合适的菜谱</text>
      </view>
    </view>

    <!-- ============================== -->
    <!-- STEP 2：食物过敏原             -->
    <!-- ============================== -->
    <view class="step-panel" wx:if="{{currentStep === 2}}">
      <view class="step-header">
        <view class="step-num">02</view>
        <view class="step-title">是否有食物过敏？</view>
        <view class="step-desc">选中后，系统将自动排除含相关食材的菜谱</view>
      </view>

      <view class="allergy-pills">
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'none') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="none"
        >
          <text class="allergy-pill__text">无过敏</text>
        </view>
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'seafood') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="seafood"
        >
          <text class="allergy-pill__text">海鲜</text>
        </view>
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'shrimp') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="shrimp"
        >
          <text class="allergy-pill__text">虾蟹</text>
        </view>
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'nuts') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="nuts"
        >
          <text class="allergy-pill__text">坚果</text>
        </view>
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'peanut') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="peanut"
        >
          <text class="allergy-pill__text">花生</text>
        </view>
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'wheat') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="wheat"
        >
          <text class="allergy-pill__text">小麦</text>
        </view>
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'soy') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="soy"
        >
          <text class="allergy-pill__text">大豆</text>
        </view>
        <view
          class="allergy-pill {{arrutils.includes(allergies, 'dairy') ? 'allergy-pill--selected' : ''}}"
          bindtap="onToggleAllergy"
          data-val="dairy"
        >
          <text class="allergy-pill__text">乳制品</text>
        </view>
      </view>

      <view class="step-actions">
        <view class="step-btn step-btn--ghost" bindtap="onGoBack">返回</view>
        <view class="step-btn step-btn--primary" bindtap="onNextFromAllergy">下一步</view>
      </view>
    </view>

    <!-- ============================== -->
    <!-- STEP 3：用餐时段              -->
    <!-- ============================== -->
    <view class="step-panel" wx:if="{{currentStep === 3}}">
      <view class="step-header">
        <view class="step-num">03</view>
        <view class="step-title">选择用餐时段</view>
        <view class="step-desc">根据你的饮食习惯选择，系统将优先推荐适合的菜谱</view>
      </view>

      <view class="meal-cards-row">
        <view
          class="meal-card {{arrutils.includes(mealTimes, 'breakfast') ? 'meal-card--selected' : ''}}"
          bindtap="onToggleMealTime"
          data-val="breakfast"
        >
          <image class="meal-card__icon-img" src="/assets/早餐.png" mode="aspectFit" />
          <view class="meal-card__name">早餐</view>
        </view>

        <view
          class="meal-card {{arrutils.includes(mealTimes, 'lunch') ? 'meal-card--selected' : ''}}"
          bindtap="onToggleMealTime"
          data-val="lunch"
        >
          <image class="meal-card__icon-img" src="/assets/午餐.png" mode="aspectFit" />
          <view class="meal-card__name">午餐</view>
        </view>

        <view
          class="meal-card {{arrutils.includes(mealTimes, 'dinner') ? 'meal-card--selected' : ''}}"
          bindtap="onToggleMealTime"
          data-val="dinner"
        >
          <image class="meal-card__icon-img" src="/assets/晚餐.png" mode="aspectFit" />
          <view class="meal-card__name">晚餐</view>
        </view>
      </view>

      <view class="meal-hint" wx:if="{{mealTimes.length === 0}}">
        <text class="meal-hint__text">不选则不限时段，系统会推荐所有适合的菜谱</text>
      </view>
      <view class="meal-selected-hint" wx:if="{{mealTimes.length > 0}}">
        <text class="meal-selected-hint__text">已选 {{mealTimes.length}} 个时段</text>
      </view>

      <view class="step-actions">
        <view class="step-btn step-btn--ghost" bindtap="onGoBack">返回</view>
        <view class="step-btn step-btn--generate" bindtap="onGenerate">生成专属减脂菜单</view>
      </view>
    </view>

  </scroll-view>
</view>
