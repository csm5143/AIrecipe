/* ================================================
   登录页面样式 - 现代化设计（微信一键登录版）
   ================================================ */

/* 页面基础 */
.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #fef9f3 0%, #fff5eb 50%, #fef3e8 100%);
  position: relative;
  overflow: hidden;
}

/* 用户信息行 */
.user-info-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.phone-badge {
  padding: 4rpx 16rpx;
  background: #f0f0f5;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #8e8e93;
}

/* ================================================
   微信一键登录按钮
   ================================================ */
.btn-phone-login {
  width: 100%;
  height: auto;
  padding: 32rpx 36rpx;
  border-radius: 24rpx;
  border: none;
  background: linear-gradient(135deg, #f7c948 0%, #e2a650 100%);
  box-shadow: 0 8rpx 28rpx rgba(247, 201, 72, 0.32);
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0;
}

.btn-phone-login::after {
  border: none;
}

.btn-phone-login--locked {
  opacity: 0.5;
  box-shadow: none;
}

.btn-phone-login:active:not(.btn-phone-login--locked) {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-phone-content {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.btn-phone-icon {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
}

.btn-phone-text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.btn-phone-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1c1e;
  margin-bottom: 4rpx;
}

.btn-phone-sub {
  font-size: 22rpx;
  color: #8e8e93;
}

.btn-phone-arrow {
  font-size: 40rpx;
  color: #c7c7cc;
  font-weight: 300;
}

/* 分隔线 */
.divider-row {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  gap: 20rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e5e5e5;
}

.divider-text {
  font-size: 24rpx;
  color: #c7c7cc;
}

/* 温馨提示 */
.tips-section {
  margin-top: 32rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1c1c1e;
  margin-bottom: 16rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.tips-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 24rpx;
  color: #636366;
}

.tips-icon {
  width: 32rpx;
  height: 32rpx;
  background: #34c759;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  flex-shrink: 0;
}

/* 页面基础 */
.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #fef9f3 0%, #fff5eb 50%, #fef3e8 100%);
  position: relative;
  overflow: hidden;
}

/* 背景装饰 - 柔和的几何图形 */
.bg-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
}

.bg-circle {
  position: absolute;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(247, 201, 72, 0.15), rgba(226, 166, 80, 0.1));
}

.bg-circle--1 {
  width: 400rpx;
  height: 400rpx;
  top: -150rpx;
  right: -100rpx;
}

.bg-circle--2 {
  width: 300rpx;
  height: 300rpx;
  top: 60%;
  left: -120rpx;
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.1), rgba(16, 176, 86, 0.05));
}

.bg-circle--3 {
  width: 200rpx;
  height: 200rpx;
  bottom: 15%;
  right: -60rpx;
  background: linear-gradient(135deg, rgba(255, 165, 0, 0.08), rgba(247, 201, 72, 0.05));
}

/* 主容器 */
.login-container {
  position: relative;
  z-index: 1;
  padding: 0 40rpx;
  padding-top: 80rpx;
}

/* ================================================
   品牌区域
   ================================================ */
.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.brand-logo-wrap {
  position: relative;
  margin-bottom: 24rpx;
}

.brand-logo {
  width: 140rpx;
  height: 140rpx;
  border-radius: 32rpx;
  box-shadow: 0 12rpx 40rpx rgba(226, 166, 80, 0.3);
  position: relative;
  z-index: 1;
}

.brand-logo-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 180rpx;
  height: 180rpx;
  background: radial-gradient(circle, rgba(247, 201, 72, 0.3) 0%, transparent 70%);
  border-radius: 50%;
  z-index: 0;
}

.brand-tagline {
  font-size: 26rpx;
  color: #8e8e93;
  letter-spacing: 1rpx;
  text-align: center;
  max-width: 520rpx;
  line-height: 1.45;
}

/* ================================================
   已登录状态 - 用户卡片
   ================================================ */
.logged-in-section {
  animation: fadeIn 0.4s ease-out;
}

.user-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.user-card-header {
  display: flex;
  justify-content: center;
  margin-bottom: 28rpx;
}

.avatar-btn-large {
  padding: 0;
  background: transparent;
  border: none;
  border-radius: 50%;
  position: relative;
}

.avatar-btn-large::after {
  border: none;
}

.avatar-img-large {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid #f7c948;
  box-shadow: 0 8rpx 24rpx rgba(247, 201, 72, 0.2);
}

.avatar-edit-badge {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #f7c948, #e2a650);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(226, 166, 80, 0.3);
}

.avatar-edit-badge image {
  width: 28rpx;
  height: 28rpx;
}

.user-card-body {
  text-align: center;
}

.user-nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #1c1c1e;
  margin-bottom: 12rpx;
}

.user-login-badge {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #e8f8f0, #d4f5e6);
  border-radius: 999rpx;
}

.badge-dot {
  width: 12rpx;
  height: 12rpx;
  background: #34c759;
  border-radius: 50%;
  margin-right: 8rpx;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.badge-text {
  font-size: 24rpx;
  color: #34c759;
  font-weight: 600;
}

/* 功能菜单 */
.menu-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx;
  transition: background-color 0.2s;
}

.menu-item:active {
  background-color: #f8f8f8;
}

.menu-item-left {
  display: flex;
  align-items: center;
}

.menu-item-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: #f5f5f7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-item-icon image {
  width: 32rpx;
  height: 32rpx;
}

.menu-item-icon--edit {
  background: linear-gradient(135deg, #f7c94820, #f7c94810);
}

.menu-item-icon--logout {
  background: linear-gradient(135deg, #ff3b3030, #ff3b3010);
}

.menu-item-text {
  font-size: 30rpx;
  color: #1c1c1e;
}

.menu-item-text--danger {
  color: #ff3b30;
}

.menu-item-right {
  display: flex;
  align-items: center;
}

.menu-item-value {
  font-size: 26rpx;
  color: #8e8e93;
  margin-right: 12rpx;
}

.menu-arrow {
  font-size: 36rpx;
  color: #c7c7cc;
  font-weight: 300;
}

.menu-divider {
  height: 1rpx;
  background: #f0f0f5;
  margin: 0 32rpx;
}

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(24rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ================================================
   未登录：主操作区（协议 + 微信一键登录按钮）
   ================================================ */
.login-sheet {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 12rpx 48rpx rgba(0, 0, 0, 0.06);
  animation: slideUp 0.45s ease-out;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.btn-wechat {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  border: none;
  background: linear-gradient(180deg, #07c160 0%, #06ae56 100%);
  box-shadow: 0 8rpx 28rpx rgba(7, 193, 96, 0.32);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
  margin: 0;
  padding: 0;
}

.btn-wechat::after {
  border: none;
}

.btn-wechat--locked {
  opacity: 0.5;
  box-shadow: 0 4rpx 14rpx rgba(7, 193, 96, 0.12);
}

.btn-wechat:active:not(.btn-wechat--locked) {
  transform: scale(0.98);
  opacity: 0.94;
}

.btn-wechat-icon {
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
}

.guest-entry {
  text-align: center;
  font-size: 26rpx;
  color: #8e8e93;
  padding: 22rpx 0 0;
}

.guest-entry:active {
  color: #636366;
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  padding-top: 24rpx;
  padding-left: 50rpx;
}

.agreement-checkbox {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-icon {
  width: 35rpx;
  height: 35rpx;
}

.agreement-inline {
  flex: 1;
  font-size: 24rpx;
  line-height: 36rpx;
  color: #636366;
  text-align: left;
  padding-top: 3rpx;
}

.agreement-plain {
  color: #636366;
}

.agreement-inline .agreement-link {
  color: #2c6ecb;
  font-size: 24rpx;
  display: inline;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* ================================================
   昵称编辑弹窗
   ================================================ */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.modal-box {
  position: relative;
  width: 600rpx;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease-out;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 36rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1c1c1e;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #c7c7cc;
  font-weight: 300;
}

.modal-body {
  padding: 32rpx 36rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  background: #f8f8f8;
  border-radius: 20rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1c1c1e;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  padding: 0 36rpx 36rpx;
  gap: 20rpx;
}

.modal-btn-cancel,
.modal-btn-confirm {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.modal-btn-cancel {
  background: #f5f5f7;
  color: #636366;
}

.modal-btn-cancel:active {
  background: #e8e8e8;
}

.modal-btn-confirm {
  background: linear-gradient(135deg, #07c160 0%, #10b056 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(7, 193, 96, 0.3);
}

.modal-btn-confirm:active {
  transform: scale(0.98);
}
