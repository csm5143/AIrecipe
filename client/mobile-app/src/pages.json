{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue",
      "^ai-(.*)": "@/components/ai-$1/index.vue",
      "^app-(.*)": "@/components/app-$1/index.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "首页",
        "navigationStyle": "custom",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/search/index",
      "style": {
        "navigationBarTitleText": "搜索",
        "enablePullDownRefresh": false
      }
    },
    {
      "path": "pages/scan/index",
      "style": {
        "navigationBarTitleText": "拍照识别",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/recipe/list",
      "style": {
        "navigationBarTitleText": "菜谱列表",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/recipe/detail",
      "style": {
        "navigationBarTitleText": "菜谱详情",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/collection/index",
      "style": {
        "navigationBarTitleText": "我的收藏",
        "enablePullDownRefresh": true
      }
    },
    {
      "path": "pages/mine/index",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarStyle": "black",
        "navigationStyle": "custom"
      }
    }
  ],
  "subPackages": [
    {
      "root": "pages-sub/kids",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "儿童营养",
            "enablePullDownRefresh": false
          }
        },
        {
          "path": "menu",
          "style": {
            "navigationBarTitleText": "儿童食谱"
          }
        }
      ]
    },
    {
      "root": "pages-sub/fitness",
      "pages": [
        {
          "path": "index",
          "style": {
            "navigationBarTitleText": "健身餐",
            "enablePullDownRefresh": false
          }
        },
        {
          "path": "menu",
          "style": {
            "navigationBarTitleText": "健身食谱"
          }
        }
      ]
    }
  ],
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "吃了么",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F8F8F8"
  },
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#FF9500",
    "borderStyle": "white",
    "backgroundColor": "#FFFFFF",
    "list": [
      {
        "pagePath": "pages/index/index",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/search/index",
        "iconPath": "static/tabbar/search.png",
        "selectedIconPath": "static/tabbar/search-active.png",
        "text": "搜索"
      },
      {
        "pagePath": "pages/scan/index",
        "iconPath": "static/tabbar/scan.png",
        "selectedIconPath": "static/tabbar/scan-active.png",
        "text": "拍照"
      },
      {
        "pagePath": "pages/collection/index",
        "iconPath": "static/tabbar/collection.png",
        "selectedIconPath": "static/tabbar/collection-active.png",
        "text": "收藏"
      },
      {
        "pagePath": "pages/mine/index",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine-active.png",
        "text": "我的"
      }
    ]
  },
  "uniIdRouter": {},
	"condition" : { //模式配置，仅开发期间生效
		"current": 0, //当前激活的模式(list 的索引项)
		"list": [
			{
				"name": "", //模式名称
				"path": "", //启动页面，必选
				"query": "" //启动参数，在页面的onLoad函数里面得到
			}
		]
	}
}
