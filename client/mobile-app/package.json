{
  "name": "@airecipe/mobile-app",
  "version": "1.0.0",
  "private": true,
  "description": "AIRecipe 跨端移动应用 (Taro)",
  "scripts": {
    "dev:weapp": "taro build --type weapp --watch",
    "dev:h5": "taro build --type h5 --watch",
