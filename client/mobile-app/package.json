    "pinia": "^2.1.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@tarojs/cli": "^3.6.0",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "babel-preset-taro": "^3.6.0",
    "eslint": "^8.56.0",
    "eslint-config-taro": "^3.6.0",
