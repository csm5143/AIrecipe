{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/vue3-recommended"
  ],
  "parser": "vue-eslint-parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "parser": "@typescript-eslint/parser"
  },
  "plugins": ["@typescript-eslint", "vue"],
  "rules": {
    "vue/multi-word-component-names": "off",
    "no-console": "warn",
    "vue/no-v-html": "off"
  },
  "ignorePatterns": ["dist/", "node_modules/", "coverage/", "*.d.ts"]
}
